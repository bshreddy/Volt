{
    "name": "HpArch",
    "build": {
        "dockerfile": "Dockerfile",
        "options": [
            "--platform=linux/amd64"
        ],
        "context": ".."
    },
    "runArgs": [
        "--name",
        "hparch"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "llvm-vs-code-extensions.lldb-dap",
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools"
            ]
        }
    }
}
